<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF4F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ticketeer"
            android:textColor="#C62839"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Mon billet"
            android:textColor="#1E1E1E"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- 卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_search_card"
            android:padding="20dp"
            android:elevation="4dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRoute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paris → Lyon"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"/>

            <TextView
                android:id="@+id/tvTrain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="TGV INOUI 8391"
                android:textSize="16sp"
                android:textColor="#5B5B5B"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="2026-04-10 08:00"
                android:textSize="15sp"
                android:textColor="#7A7A7A"/>

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="89,90 €"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"/>

        </LinearLayout>

        <!-- QR CODE 占位 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_search_card"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgQrCode"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:contentDescription="QR Code" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvLiveInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_search_card"
            android:padding="16dp"
            android:textColor="#1E1E1E"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvPassengerInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search_card"
            android:padding="16dp"
            android:textColor="#1E1E1E"
            android:textSize="16sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnPdf"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_purple_button"
            android:text="Télécharger PDF"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btnModify"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:text="Modifier le billet"
            android:textColor="#1E1E1E"/>

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:text="Annuler le billet"
            android:textColor="#1E1E1E"/>

        <Button
            android:id="@+id/btnSupport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:text="Support / contact"
            android:textColor="#1E1E1E"/>

        <Button
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:text="Retour à l'accueil"
            android:textColor="#1E1E1E"/>

    </LinearLayout>

</ScrollView>
