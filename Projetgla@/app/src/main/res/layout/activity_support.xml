<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF4F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ticketeer"
            android:textColor="#C62839"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Support client"
            android:textColor="#1E1E1E"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Besoin d’aide pour un paiement, une modification ou un retard ?"
            android:textColor="#7A7A7A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_search_card"
            android:padding="20dp"
            android:text="Email : support@ticketeer.app&#10;Téléphone : +33 1 80 00 12 34&#10;Horaires : 7j/7, 06:00-23:00"
            android:textColor="#1E1E1E"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnSupportEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_purple_button"
            android:text="Contacter par email"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnSupportPhone"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:text="Appeler le support"
            android:textAllCaps="false"
            android:textColor="#1E1E1E" />

    </LinearLayout>
</ScrollView>
